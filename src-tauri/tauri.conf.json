{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenAEC Installer",
  "version": "0.1.7",
  "identifier": "com.openaec.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3020",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "OpenAEC Installer",
        "width": 1180,
        "height": 780,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
